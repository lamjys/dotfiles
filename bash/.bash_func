### Archive extraction
# usage: ex <file>
ex()
{
    if [ -f "$1" ] ; then
        case $1 in
            *.tar.bz2)    tar xjf $1    ;;
            *.tar.gz)     tar xzf $1    ;;
            *.bz2)        bunzip2 $1    ;;
            *.rar)        unrar x $1    ;;
            *.gz)         gunzip  $1    ;;
            *.tar)        tar xf  %1    ;;
            *.tbz2)       tar xjf %1    ;;
            *.tgz)        tar xzf %1    ;;
            *.zip)        unzip   $1    ;;
            *.Z)          uncompress $1 ;;
            *.7z)         7z x    $1    ;;
            *.deb)        ar x    $1    ;;
            *.tar.xz)     tar xf  %1    ;;
            *.tar.zst)    unzstd  %1    ;;
            *.md)         glow    $1    ;;
            *)            echo "'$1' cannot be extracted via ex()" ;;
        esac
    else
        echo "'$1' is not a valid file"
    fi
}

# fzf to read csv file where freq cmd stored
_readline_from_csv() {
    local BUFFER
    if BUFFER=$(<~/appdata/mdnotes/commands.csv fzf --delimiter=, --with-nth=2 --reverse | awk -F, '{print $3}'); then
        READLINE_LINE=${BUFFER}
        READLINE_POINT=${#READLINE_LINE}
    fi
}
bind -x '"\C-x\C-r": _readline_from_csv'

# openvpn config file to feed to auth user pass from age decrypt
myov() {
    # 檢查是否有輸入參數（伺服器網址）
    if [ -z "$1" ]; then
        echo "使用方法: myov <server-address>"
        echo "範例: myov za-jnb"
        return 1
    fi

    # 定義變數以簡化後續指令
    local KEY_FILE="/home/nana/.config/sops/age/keys.txt"
    local CRED_FILE="/home/nana/Nextcloud/Keys/surfshark/surfshark_credential.txt.age"
    local SERVER_CONFIG="${1}.prod.surfshark.com_udp.ovpn"

    # 執行指令
    sudo bash -c "openvpn --config $SERVER_CONFIG --auth-user-pass <(echo -e \"\$(age -d -i $KEY_FILE $CRED_FILE | head -n 2 | tail -n 1)\n$(age -d -i $KEY_FILE $CRED_FILE | head -n 10 | tail -n 1)\")"
}

